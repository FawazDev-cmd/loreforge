# LoreForge environment template
# Copy to .env for local use. Never commit real secrets.

# Application
LOREFORGE_ENVIRONMENT=development
LOREFORGE_SERVICE_NAME=loreforge
LOREFORGE_API_TITLE=LoreForge
LOREFORGE_API_VERSION=0.1.0
LOREFORGE_PUBLIC_BASE_URL=

# API
LOREFORGE_API_HOST=127.0.0.1
LOREFORGE_API_PORT=8000
LOREFORGE_CORS_ALLOWED_ORIGINS=

# Logging
LOREFORGE_LOG_LEVEL=info
LOREFORGE_STRUCTURED_LOGGING=false
LOREFORGE_REQUEST_LOGGING_ENABLED=true

# Provider selection. Providers remain disabled until explicitly configured.
LOREFORGE_DOCUMENT_EMBEDDINGS_PROVIDER=disabled
LOREFORGE_QUERY_EMBEDDINGS_PROVIDER=disabled
LOREFORGE_RERANKER_PROVIDER=disabled
LOREFORGE_LLM_PROVIDER=disabled

# Gemini provider placeholders. Day 32 does not implement Gemini adapters.
LOREFORGE_GEMINI_API_KEY=
LOREFORGE_GEMINI_GENERATION_MODEL=
LOREFORGE_GEMINI_EMBEDDING_MODEL=
LOREFORGE_GEMINI_TIMEOUT_SECONDS=30.0

# OpenRouter provider placeholders. OpenRouter is not wired by default.
LOREFORGE_OPENROUTER_API_KEY=
LOREFORGE_OPENROUTER_MODEL=
LOREFORGE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LOREFORGE_OPENROUTER_TIMEOUT_SECONDS=30.0

# Local provider placeholders. Models load only when a local provider is explicitly used.
LOREFORGE_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOREFORGE_LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
LOREFORGE_LOCAL_BATCH_SIZE=32

# Database placeholders. Persistence is not implemented yet.
LOREFORGE_DATABASE_URL=
LOREFORGE_DATABASE_POOL_MIN_SIZE=1
LOREFORGE_DATABASE_POOL_MAX_SIZE=5
LOREFORGE_DATABASE_MIGRATIONS_ENABLED=false
LOREFORGE_DATABASE_MIGRATIONS_PATH=migrations

# Storage placeholders. Durable storage is not implemented yet.
LOREFORGE_STORAGE_PROVIDER=local
LOREFORGE_STORAGE_LOCAL_PATH=.loreforge/storage
LOREFORGE_SUPABASE_URL=
LOREFORGE_SUPABASE_STORAGE_BUCKET=
LOREFORGE_SUPABASE_SERVICE_ROLE_KEY=

# Authentication placeholders. Authentication is not implemented yet.
LOREFORGE_AUTH_PROVIDER=disabled
LOREFORGE_AUTH_JWT_ISSUER=
LOREFORGE_AUTH_JWT_AUDIENCE=
LOREFORGE_AUTH_JWKS_URL=

# Observability
LOREFORGE_METRICS_ENABLED=true
LOREFORGE_RECORD_QUERY_OBSERVATIONS=true
